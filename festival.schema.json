{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/festival.schema.json",
  "title": "Festival Details",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "festival"
  ],
  "properties": {
    "festival": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "dates",
        "location",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "tagline": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "dates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "start",
            "end"
          ],
          "properties": {
            "start": {
              "type": "string",
              "format": "date"
            },
            "end": {
              "type": "string",
              "format": "date"
            },
            "displayText": {
              "type": "string"
            }
          }
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "venue",
            "city",
            "country"
          ],
          "properties": {
            "venue": {
              "type": "string",
              "minLength": 1
            },
            "address": {
              "type": "string"
            },
            "city": {
              "type": "string",
              "minLength": 1
            },
            "country": {
              "type": "string",
              "minLength": 1
            },
            "mapsUrl": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "websiteUrl": {
          "type": "string",
          "format": "uri"
        },
        "heroImage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "url",
            "alt"
          ],
          "properties": {
            "url": {
              "type": "string",
              "format": "uri"
            },
            "alt": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "genres": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tickets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ticket"
      }
    },
    "lineup": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/performer"
      }
    },
    "schedule": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scheduleDay"
      }
    },
    "faq": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/faqItem"
      }
    },
    "contact": {
      "$ref": "#/$defs/contact"
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    }
  },
  "$defs": {
    "ticket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "price",
        "description"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "price": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "purchaseUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "performer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "genre": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "websiteUrl": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "scheduleEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "time",
        "artist",
        "stage"
      ],
      "properties": {
        "time": {
          "type": "string",
          "minLength": 1
        },
        "artist": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "scheduleDay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "label",
        "entries"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scheduleEntry"
          }
        }
      }
    },
    "faqItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "answer"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 1
        },
        "answer": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "instagram": {
          "type": "string",
          "format": "uri"
        },
        "facebook": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    }
  }
}
